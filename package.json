{
  "name": "nlm-memory",
  "version": "0.5.2",
  "description": "Local-first non-linear memory operating system for AI operators.",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pbmagnet4/nlm-memory-ts.git"
  },
  "homepage": "https://github.com/pbmagnet4/nlm-memory-ts#readme",
  "bugs": {
    "url": "https://github.com/pbmagnet4/nlm-memory-ts/issues"
  },
  "keywords": [
    "ai",
    "memory",
    "mcp",
    "claude-code",
    "codex",
    "hermes",
    "local-first",
    "recall",
    "session-memory"
  ],
  "files": [
    "dist",
    "plugin",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "nlm": "dist/cli/nlm.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli/nlm.ts start",
    "start": "node dist/cli/nlm.js start",
    "build:server": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "build:ui": "vite build --config src/ui/vite.config.ts",
    "build:codex-plugin": "node scripts/build-codex-plugin.mjs",
    "build": "npm run build:server && npm run build:ui && npm run build:codex-plugin",
    "ui:dev": "vite --config src/ui/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "lint": "eslint src tests"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@hono/node-server": "^2.0.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@toon-format/toon": "^2.3.0",
    "better-sqlite3": "^11.5.0",
    "commander": "^12.1.0",
    "hono": "^4.6.0",
    "sqlite-vec": "^0.1.6",
    "yaml": "^2.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "esbuild": "^0.28.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.0"
  }
}
