{
  "name": "nlm-memory",
  "version": "0.3.0",
  "description": "Local-first non-linear memory operating system for AI operators.",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "nlm": "./dist/cli/nlm.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli/nlm.ts start",
    "start": "node dist/cli/nlm.js start",
    "build:server": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "build:ui": "vite build --config src/ui/vite.config.ts",
    "build": "npm run build:server && npm run build:ui",
    "ui:dev": "vite --config src/ui/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "lint": "eslint src tests"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@toon-format/toon": "^2.3.0",
    "better-sqlite3": "^11.5.0",
    "commander": "^12.1.0",
    "hono": "^4.6.0",
    "sqlite-vec": "^0.1.6",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.0"
  }
}
